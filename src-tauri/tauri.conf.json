{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipBox",
  "version": "0.1.5",
  "identifier": "com.clipbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipBox",
        "width": 420,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "ClipBox — 轻量剪贴板工具箱",
    "longDescription": "ClipBox 是一款本地优先的轻量剪贴板管理工具，支持历史记录、全文搜索、置顶、片段模板、智能搜索与中英双语界面。数据存储在本机，无云同步。"
  }
}
